# PostgreSQL
POSTGRES_DB=streaming_audio
POSTGRES_USER=streaming
POSTGRES_PASSWORD=streaming_dev
POSTGRES_PORT=5432

# MinIO (S3-compatible, desarrollo local)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_BUCKET=audio
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# Backend (Fase 1)
API_PORT=8080
JWT_ACCESS_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# Regalías (defaults, override en BD vía configuracion_sistema)
PESO_REGALIAS_PREMIUM=1.0
PESO_REGALIAS_GRATIS=0.25
TOPE_ARTISTA_PORCENTAJE=0.20

# Stripe (Fase 4)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
